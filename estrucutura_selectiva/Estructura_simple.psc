Algoritmo Estructura_Simple
	//Comparar el menor de dos numeros reales
	Definir n1, n2 Como Real;
	Escribir "Ingresar el primer numero";
	Leer n1;
	Escribir "Ingresar el segundo numero";
	Leer n2;
	//Determinar el menor
	si n1<n2 Entonces
		Escribir "El menor es: ",n1;
	FinSi
	si n2<n1 Entonces
		Escribir "El menor es: ",n2;
	FinSi
FinAlgoritmo
